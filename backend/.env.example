NOTION_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# Required for the deployed backend. Find this in chrome://extensions after
# loading Role Snippet.
ROLE_SNIPPET_EXTENSION_ID=your_chrome_extension_id

# Required by both the backend and your private local extension build.
ROLE_SNIPPET_API_KEY=your_generated_role_snippet_api_key
