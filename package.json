{
  "name": "role-snippet",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension for saving LinkedIn job post details to Notion.",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "clean": "rm -rf dist",
    "lint": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "build": "bun scripts/build.mjs",
    "verify": "bun run typecheck && bun run build",
    "backend:verify": "cd backend && bun run verify",
    "verify:all": "bun run verify && bun run backend:verify"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@notionhq/client": "^5.20.0",
    "@types/chrome": "^0.0.326",
    "@types/node": "^25.6.0",
    "@vercel/node": "^5.7.15",
    "esbuild": "^0.25.12",
    "typescript": "^5.9.3"
  }
}
