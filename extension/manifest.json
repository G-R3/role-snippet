{
  "manifest_version": 3,
  "name": "LinkSnaggedIn",
  "description": "Extract LinkedIn job post details and prepare them for Notion.",
  "version": "0.1.0",
  "action": {
    "default_title": "LinkSnaggedIn",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*"
      ],
      "js": ["content/linkedinExtractor.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://linkedin.com/jobs/*",
    "https://link-snagged-in-backend.vercel.app/*"
  ],
  "permissions": ["activeTab", "storage", "tabs"]
}
